# OpenRouter API (for Claude Agent SDK)
OPENROUTER_API_KEY=your-openrouter-api-key
# Use standard Anthropic model aliases: sonnet, opus, haiku
# Or full model IDs: claude-sonnet-4-6, claude-opus-4-6
OPENROUTER_MODEL=sonnet

# Alibaba DashScope TTS
DASHSCOPE_API_KEY=your-dashscope-api-key
# Available voices: longshuo, longwan, longjing, longhua, longcheng, longxiang,
# longfei, longshu, longjielidou, longlaotie, longmiao, longtong, longxiaobai, etc.
TTS_VOICE=longshuo
TTS_RATE=45
TTS_PITCH=25
TTS_VOLUME=60
TTS_SAMPLE_RATE=16000
TTS_FORMAT=mp3

# Video defaults
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30

# Server
HOST=0.0.0.0
PORT=8000

# Sessions directory
SESSIONS_DIR=sessions
