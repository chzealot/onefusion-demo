# LLM - Script Generation (OpenRouter)
OPENROUTER_API_KEY=sk-or-xxx
LLM_MODEL=anthropic/claude-opus-4.6

# LLM - Animation Generation (Claude Code SDK via OpenRouter)
CLAUDE_CODE_API_KEY=sk-or-xxx
CLAUDE_CODE_BASE_URL=https://openrouter.ai/api
CLAUDE_CODE_MODEL=claude-opus-4-20250514

# TTS - Alibaba Cloud DashScope
DASHSCOPE_API_KEY=sk-xxx
TTS_VOICE=longshuo
TTS_SPEED=45
TTS_PITCH=25
TTS_VOLUME=60
TTS_SAMPLE_RATE=16000
TTS_FORMAT=mp3

# Server
HOST=0.0.0.0
PORT=8000
WORKSPACES_DIR=./workspaces
