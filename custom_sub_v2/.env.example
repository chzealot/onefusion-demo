# OpenRouter API (for scriptwriter direct call + Claude Agent SDK)
OPENROUTER_API_KEY=sk-or-xxx
OPENROUTER_MODEL=anthropic/claude-sonnet-4-20250514
OPENROUTER_SCRIPTWRITER_MODEL=anthropic/claude-sonnet-4-20250514

# DashScope TTS
DASHSCOPE_API_KEY=sk-xxx
TTS_VOICE=zhishuo
TTS_RATE=45
TTS_PITCH=25
TTS_VOLUME=60
TTS_SAMPLE_RATE=16000
TTS_FORMAT=mp3

# Video defaults
VIDEO_WIDTH=1920
VIDEO_HEIGHT=1080
VIDEO_FPS=30

# Server
HOST=0.0.0.0
PORT=8000

# Paths
SESSIONS_DIR=sessions
